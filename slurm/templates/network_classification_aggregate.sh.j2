{% extends "base.sh.j2" %}

{% block job_commands %}
# =============================================================================
# Aggregate per-network classification partials → combined bundle
#   Yeo {{ yeo }}, scope={{ scope }}, trial-type={{ trial_type }} on {{ space }}
# =============================================================================

echo "Network aggregation configuration:"
echo "  Space:        {{ space }}"
echo "  Yeo:          {{ yeo }}"
echo "  Scope:        {{ scope }}"
echo "  Trial-type:   {{ trial_type }}"
echo "  Classifier:   {{ clf }}"
echo "  CV strategy:  {{ cv }}"
echo ""

python -m code.classification.aggregate_network_classification \
    --space {{ space }} \
    --yeo {{ yeo }} \
    --scope {{ scope }} \
    --trial-type {{ trial_type }} \
    --clf {{ clf }} \
    --cv {{ cv }} \
    {% if delete_partials %}--delete-partials{% endif %}

EXIT=$?
if [ $EXIT -eq 0 ]; then
    echo "Network aggregation completed successfully"
else
    echo "Network aggregation failed with exit code $EXIT"
    exit $EXIT
fi
{% endblock %}
